# =============================================================================
# FusionPrints environment variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Database ---
# In WSL/Ubuntu, this should match your local Postgres setup.
# Replace 'yourname' with your actual Ubuntu username (whoami in terminal).
DATABASE_URL=postgresql://yourname@localhost:5432/fusionprints_dev

# --- Business identity (used in bot messages) ---
BUSINESS_NAME=FusionPrints
BUSINESS_PHONE=+263XXXXXXXXX
BUSINESS_LOCATION_NAME=Harare
BUSINESS_COLLECTION_ADDRESS="Address TBD, Harare"
BUSINESS_HOURS="Mon-Sat, 9am-6pm"

# --- WhatsApp (360dialog) — leave blank until you have credentials ---
WHATSAPP_BSP=360dialog
WHATSAPP_API_KEY=
WHATSAPP_API_BASE=https://waba-v2.360dialog.io
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- Payments — leave blank until you have credentials ---
PAYNOW_INTEGRATION_ID=
PAYNOW_INTEGRATION_KEY=
PAYNOW_RETURN_URL=
PAYNOW_RESULT_URL=

FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_HASH=

# --- Image storage (Backblaze B2) — leave blank for now ---
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=

# --- Print agent authentication ---
# Generate a random string later: `openssl rand -hex 32`
PRINT_AGENT_API_KEY=

# --- Admin dashboard ---
# Generate later: `openssl rand -hex 32`
ADMIN_SESSION_SECRET=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Image expiry cleanup (Phase 2.1.6) ---
# Daily in-process job deletes web uploads past their 90-day retention.
# ENABLED=false turns the scheduler off entirely.
# DRY_RUN=true (default) only LOGS what it would delete; set false to delete.
IMAGE_CLEANUP_ENABLED=true
IMAGE_CLEANUP_DRY_RUN=true

# --- Google OAuth (Phase 2.1.7) — leave blank to disable Google sign-in ---
# Create at console.cloud.google.com → APIs & Services → Credentials →
# OAuth client ID (Web application). Authorized redirect URI must be:
#   dev:  http://localhost:3000/web/api/auth/google/callback
#   prod: https://api.fusionprints.co.zw/web/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloud photo import (web). Surfaced to the frontend via /web/api/imports/config.
# Turn Google Photos on (true) only AFTER the Google Cloud setup: enable the
# Photos Picker API, add scope photospicker.mediaitems.readonly to the consent
# screen, and register redirect URI {PUBLIC_URL}/web/api/imports/google/callback.
GOOGLE_PHOTOS_IMPORT_ENABLED=false
# PLANNED — not read by code yet. Dropbox Chooser app key (developers.dropbox.com).
DROPBOX_APP_KEY=

# --- URLs ---
# Backend's own public base URL (OAuth callbacks, upload links).
PUBLIC_URL=http://localhost:3000
# Frontend origin — CORS allowlist + links in transactional email.
WEB_URL=http://localhost:3001

# --- Business identity (continued) ---
# Street address shown in the "order ready for pickup" message.
BUSINESS_ADDRESS=

# --- WhatsApp (360dialog, continued) ---
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
# Approved template names for the pickup/delivery notifications + language code.
WHATSAPP_TEMPLATE_PICKUP=
WHATSAPP_TEMPLATE_DELIVERY=
WHATSAPP_TEMPLATE_LANG=en
# Basic auth on the inbound webhook POST. EMPTY = webhook is OPEN — set both
# in prod and register the credentialed URL in the 360dialog dashboard.
WHATSAPP_WEBHOOK_USER=
WHATSAPP_WEBHOOK_PASS=

# --- Payments ---
# Active gateway: stub (dev mock) | payonify.
PAYMENT_PROVIDER=stub
PAYONIFY_PUBLISHABLE_KEY=
PAYONIFY_SECRET_KEY=
PAYONIFY_WEBHOOK_SECRET=

# --- QuickBooks Online ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=

# --- Transactional email (Resend) ---
RESEND_API_KEY=
# Internal ops alerts (e.g. the 5×7 media-swap alert) are emailed here.
OPERATOR_ALERT_EMAIL=notify@fusionprints.co.zw

# --- Web platform sessions ---
# Cookie-session secret for web users; empty = falls back to ADMIN_SESSION_SECRET.
WEB_SESSION_SECRET=

# --- Operator role + kiosk autologin ---
OPERATOR_USERNAME=operator
OPERATOR_PASSWORD=changeme-operator
# Token for the Beelink kiosk's /admin/autologin shortcut; empty = disabled.
BEELINK_AUTOLOGIN_TOKEN=

# --- Printing ---
# Windows printer name the agent targets (informational on the backend side).
DNP_PRINTER_NAME=
# Virtual-printer simulator: drives queued jobs to done with NO hardware.
# Never run alongside the real print agent in prod. Disable before launch.
VIRTUAL_PRINTERS=false
VIRTUAL_PRINT_MS=2500
VIRTUAL_POLL_MS=1500
